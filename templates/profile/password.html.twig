{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block body %}
<div class="dashboard-page">
    <aside class="dashboard-sidebar">
        <div class="sidebar-brand">Websites Manager Hub</div>

        <nav class="sidebar-nav">
            <a href="{{ path('app_dashboard') }}">Websites</a>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_user_index') }}">Users</a>
            {% endif %}

            <a href="{{ path('app_profile_edit') }}" class="active">My Profile</a>
        </nav>

        <a href="{{ path('app_logout') }}" class="logout-link">Logout</a>
    </aside>

    <main class="dashboard-main">
        <header class="dashboard-header dashboard-header-row">
            <div>
                <h1>Change Password</h1>
                <p>Update your login password.</p>
            </div>

            <a href="{{ path('app_profile_edit') }}" class="btn btn-light">
                Back to Profile
            </a>
        </header>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="website-form-card">
            {{ form_start(form, { attr: { class: 'website-form' } }) }}
                <section class="website-form-section">
                    <div class="form-grid">
                        {{ form_row(form.currentPassword) }}
                        {{ form_row(form.newPassword) }}
                        {{ form_row(form.confirmPassword) }}
                    </div>
                </section>

                <div class="website-form-actions">
                    <button class="btn btn-primary btn-lg">Change Password</button>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
</div>
{% endblock %}