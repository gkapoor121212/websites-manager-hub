{% extends 'dashboard/layout.html.twig' %}

{% set active_nav = 'websites' %}

{% block title %}{{ website.name }}{% endblock %}

{% block dashboard_content %}
<header class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-3xl font-black tracking-tight text-slate-950">
            {{ website.name }}
        </h1>
        <p class="mt-2 break-all text-slate-500">
            {{ website.url }}
        </p>
    </div>

    <a href="{{ path('app_dashboard') }}"
       class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-black text-slate-700 shadow-sm ring-1 ring-slate-200 transition hover:bg-slate-50">
        Back
    </a>
</header>

<div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">

    <section class="overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-slate-200">
        <div class="h-72 bg-gradient-to-br from-blue-100 to-indigo-100">
            {% if website.screenshotPath %}
                <img src="{{ asset(website.screenshotPath) }}"
                     alt="{{ website.name }}"
                     class="h-full w-full object-cover">
            {% else %}
                <div class="flex h-full items-center justify-center px-8 text-center text-2xl font-black text-blue-900">
                    {{ website.hostname }}
                </div>
            {% endif %}
        </div>

        <div class="p-8">
            <h2 class="text-2xl font-black text-slate-950">
                {{ website.name }}
            </h2>
            <a href="{{ website.url }}"
               target="_blank"
               rel="noopener noreferrer"
               class="mt-2 inline-block break-all text-sm font-bold text-blue-600 hover:text-blue-700">
                {{ website.url }}
            </a>
        </div>
    </section>

    <section class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-xl font-black text-slate-950">
            Website Details
        </h2>

        <dl class="mt-6 divide-y divide-slate-200">
            <div class="py-4 first:pt-0">
                <dt class="text-xs font-black uppercase tracking-widest text-slate-400">Admin Login URL</dt>
                <dd class="mt-2 break-all text-sm font-bold text-slate-800">
                    {% if website.adminLoginURL %}
                        <a href="{{ website.adminLoginURL }}" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-700">
                            {{ website.adminLoginURL }}
                        </a>
                    {% else %}
                        —
                    {% endif %}
                </dd>
            </div>

            <div class="py-4">
                <dt class="text-xs font-black uppercase tracking-widest text-slate-400">Server</dt>
                <dd class="mt-2 text-sm font-bold text-slate-800">{{ website.server ?: '—' }}</dd>
            </div>

            <div class="py-4">
                <dt class="text-xs font-black uppercase tracking-widest text-slate-400">HTTP Authentication</dt>
                <dd class="mt-2 text-sm font-bold text-slate-800">
                    {{ website.hasHttpAuth ? 'Enabled' : 'Not used' }}
                </dd>
            </div>

            <div class="py-4">
                <dt class="text-xs font-black uppercase tracking-widest text-slate-400">Created</dt>
                <dd class="mt-2 text-sm font-bold text-slate-800">{{ website.created|date('d M Y, H:i') }}</dd>
            </div>

            <div class="py-4 last:pb-0">
                <dt class="text-xs font-black uppercase tracking-widest text-slate-400">Updated</dt>
                <dd class="mt-2 text-sm font-bold text-slate-800">{{ website.updated|date('d M Y, H:i') }}</dd>
            </div>
        </dl>
    </section>

    <section class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200 xl:col-span-2">
        <h2 class="text-xl font-black text-slate-950">
            Notes
        </h2>

        {% if website.notes %}
            <div class="prose prose-slate mt-4 max-w-none">
                <p class="whitespace-pre-line text-slate-700">{{ website.notes }}</p>
            </div>
        {% else %}
            <p class="mt-4 text-slate-500">No notes added yet.</p>
        {% endif %}
    </section>

</div>
{% endblock %}