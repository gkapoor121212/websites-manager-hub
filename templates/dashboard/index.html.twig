{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="dashboard-page">

    <aside class="dashboard-sidebar">
        <div class="sidebar-brand">Websites Manager Hub</div>

        <nav class="sidebar-nav">
            <a href="{{ path('app_dashboard') }}" class="active">Websites</a>
        </nav>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_user_index') }}">Users</a>
        {% endif %}

        <a href="{{ path('app_profile_edit') }}">My Profile</a>

        <a href="{{ path('app_logout') }}" class="logout-link">Logout</a>
    </aside>

    <main class="dashboard-main">

        <header class="dashboard-header dashboard-header-row">
            <div>
                <h1>Websites</h1>
                <p>All websites added to the system.</p>
            </div>

            <a href="{{ path('app_website_new') }}" class="btn btn-primary">
                Add Website
            </a>
        </header>

        {% if websites is empty %}
            <div class="empty-state">
                <h2>No websites yet</h2>
                <p>Add your first website to start managing it.</p>
                <a href="{{ path('app_website_new') }}" class="btn btn-primary">
                    Add Website
                </a>
            </div>
        {% else %}
            <section class="website-grid">
                {% for website in websites %}
                    <a href="{{ path('app_website_show', { id: website.id }) }}" class="website-card">
                    <div class="website-preview">
                        {% if website.screenshotPath %}
                            <img src="{{ asset(website.screenshotPath) }}" alt="{{ website.name }}">
                        {% else %}
                            <span>{{ website.hostname }}</span>
                        {% endif %}
                        </div>
                        <div class="website-card-body">
                            <h2>{{ website.name }}</h2>
                            <p>{{ website.url }}</p>
                        </div>
                    </a>
                {% endfor %}
            </section>
        {% endif %}

    </main>

</div>
{% endblock %}
