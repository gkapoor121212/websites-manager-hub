{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen bg-slate-100 lg:grid lg:grid-cols-[280px_1fr]">

    <aside class="bg-slate-950 text-white p-6 lg:p-8 flex flex-col min-h-screen">
        <div class="mb-10">
            <div class="text-xl font-black tracking-tight">
                Websites Manager Hub
            </div>
            <div class="mt-2 text-sm text-white/50">
                Website dashboard
            </div>
        </div>

        <nav class="flex flex-col gap-2">
            <a href="{{ path('app_dashboard') }}"
               class="rounded-2xl px-4 py-3 text-sm font-bold transition {{ active_nav|default('') == 'websites' ? 'bg-white text-slate-950' : 'text-white/70 hover:bg-white/10 hover:text-white' }}">
                Websites
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_user_index') }}"
                   class="rounded-2xl px-4 py-3 text-sm font-bold transition {{ active_nav|default('') == 'users' ? 'bg-white text-slate-950' : 'text-white/70 hover:bg-white/10 hover:text-white' }}">
                    Users
                </a>
            {% endif %}

            <a href="{{ path('app_profile_edit') }}"
               class="rounded-2xl px-4 py-3 text-sm font-bold transition {{ active_nav|default('') == 'profile' ? 'bg-white text-slate-950' : 'text-white/70 hover:bg-white/10 hover:text-white' }}">
                My Profile
            </a>
        </nav>

        <div class="mt-auto pt-8">
            <div class="mb-4 rounded-2xl bg-white/5 p-4">
                <div class="text-sm font-bold">
                    {{ app.user.name|default(app.user.userIdentifier) }}
                </div>
                <div class="mt-1 text-xs text-white/50">
                    {{ app.user.designation|default('User') }}
                </div>
            </div>

            <a href="{{ path('app_logout') }}"
               class="block rounded-2xl px-4 py-3 text-sm font-bold text-white/70 transition hover:bg-white/10 hover:text-white">
                Logout
            </a>
        </div>
    </aside>

    <main class="p-6 lg:p-10">
        {% block dashboard_content %}{% endblock %}
    </main>

</div>
{% endblock %}